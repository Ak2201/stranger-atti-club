# ---------- Razorpay ----------
# Get from https://dashboard.razorpay.com/app/keys (test_ keys first, then live_)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=https://strangeratticlub.vercel.app
NEXT_PUBLIC_CONTACT_EMAIL=hello@strangeratticlub.in
NEXT_PUBLIC_WHATSAPP=917530036130
NEXT_PUBLIC_INSTAGRAM=strangeratticlub

# ---------- Auth.js (NextAuth v5) ----------
# Random secret for session cookies. Generate one with: openssl rand -hex 32
AUTH_SECRET=REPLACE_ME

# ---------- Google OAuth ----------
# 1. https://console.cloud.google.com → New project
# 2. APIs & Services → OAuth consent screen → External → fill basic info
# 3. APIs & Services → Credentials → Create Credentials → OAuth client ID
#    Type: Web application
#    Authorized redirect URI: http://localhost:3000/api/auth/callback/google
#    (and https://YOUR_DOMAIN/api/auth/callback/google for prod)
# 4. Copy Client ID + Secret here
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Toggle on the public client when Google is configured
NEXT_PUBLIC_HAS_GOOGLE_AUTH=

# ---------- Admin access ----------
# Comma-separated list of Google emails that get admin role on sign-in.
# Admin can do operational work (check-in, walk-in, expenses, blasts).
# Demo mode (no Google keys) auto-promotes the demo user to super_admin.
ADMIN_EMAILS=arun.aaron@zohocorp.com

# Super admin (owner) — comma-separated emails. Can do everything admin can,
# PLUS destructive actions (refund, delete) and team/role management.
# Super admin implies admin (no need to list them in both).
SUPER_ADMIN_EMAILS=arun.aaron@zohocorp.com

# Vendor (bartender / food / merch staff) — comma-separated emails.
# Vendors can ONLY access /admin/check-in and /admin/redeem. They cannot see
# bookings, finance, attendees, or any other admin tooling.
VENDOR_EMAILS=

# ---------- Database (Turso libSQL) ----------
# Free tier: 500 DBs, 9GB storage, 1B row reads/month — no credit card.
# 1. Sign up at https://turso.tech
# 2. `turso db create stranger-atti-club`
# 3. `turso db show stranger-atti-club` → copy URL
# 4. `turso db tokens create stranger-atti-club` → copy auth token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
